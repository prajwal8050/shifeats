<?xml version="1.0" encoding="UTF-8"?>
<svg width="300" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="grad-ice-cream">
      <stop offset="0%" style="stop-color:rgba(255,255,255,0.3);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.1);stop-opacity:1" />
    </radialGradient>
  </defs>
  <rect width="300" height="300" fill="#F0E68C"/>
  <rect width="300" height="300" fill="url(#grad-ice-cream)"/>
  <text x="150" y="150" font-size="150" text-anchor="middle" dominant-baseline="middle">🍦</text>
  <text x="150" y="255" font-family="Arial, sans-serif" font-size="24" font-weight="bold" 
        text-anchor="middle" fill="#FF69B4" 
        style="text-shadow: 0 2px 4px rgba(255,255,255,0.8);">ICE CREAM</text>
</svg>
